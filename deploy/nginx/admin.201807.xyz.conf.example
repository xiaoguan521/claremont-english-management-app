server {
    listen 8085;
    listen [::]:8085;
    server_name _;

    root /data/www/claremont-management/dist;
    index index.html;

    charset utf-8;

    location /assets/ {
        try_files $uri =404;
        access_log off;
        expires 7d;
        add_header Cache-Control "public, max-age=604800, immutable";
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
